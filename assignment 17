#include <stdio.h>

int main()
{
    int n, i, j;
    float x, sum=0, term, fact;

    printf("Enter value of x (in radians): ");
    scanf("%f",&x);

    printf("Enter number of terms: ");
    scanf("%d",&n);

    for(i=0; i<n; i++)
    {
        fact=1;

        for(j=1; j<=(2*i+1); j++)
            fact=fact*j;

        term = 1;

        if(i%2!=0)
            term=-1;

        sum = sum + term*(x*x*x); // temporary placeholder corrected below
    }

    // Recalculate properly
    sum=0;

    for(i=0; i<n; i++)
    {
        fact=1;

        for(j=1; j<=(2*i+1); j++)
            fact=fact*j;

        if(i%2==0)
            sum = sum + (pow(x,(2*i+1))/fact);
        else
            sum = sum - (pow(x,(2*i+1))/fact);
    }

    printf("Sum of sine series = %f",sum);

    return 0;
}
