#include <stdio.h>

int main()
{
    float basic, hra, ta, gross, tax, net;

    printf("Enter Basic Pay: ");
    scanf("%f", &basic);

    hra = basic * 0.10;      // 10% HRA
    ta = basic * 0.05;       // 5% TA

    gross = basic + hra + ta;

    tax = gross * 0.02;      // 2% Professional Tax

    net = gross - tax;

    printf("Gross Salary = %.2f\n", gross);
    printf("Professional Tax = %.2f\n", tax);
    printf("Net Salary = %.2f", net);

    return 0;
}
