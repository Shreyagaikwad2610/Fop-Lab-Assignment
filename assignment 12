#include <stdio.h>

int main()
{
    int a, b, i, gcd;

    printf("Enter two numbers: ");
    scanf("%d%d", &a, &b);

    // Smallest Common Divisor (other than 1)
    for(i=2; i<=a && i<=b; i++)
    {
        if(a%i==0 && b%i==0)
        {
            printf("Smallest Common Divisor = %d\n", i);
            break;
        }
    }

    if(i>a || i>b)
        printf("No Common Divisor other than 1\n");

    // GCD
    for(i=1; i<=a && i<=b; i++)
    {
        if(a%i==0 && b%i==0)
            gcd=i;
    }

    printf("GCD = %d", gcd);

    return 0;
}
