#include <stdio.h>

int main()
{
   int i,j,r,c;
   int A[10][10],B[10][10],sum[10][10];

   // 1. Matrix Addition
   printf("Enter rows and columns for addition: ");
   scanf("%d%d",&r,&c);

   printf("Enter First Matrix:\n");
   for(i=0;i<r;i++)
   for(j=0;j<c;j++)
   scanf("%d",&A[i][j]);

   printf("Enter Second Matrix:\n");
   for(i=0;i<r;i++)
   for(j=0;j<c;j++)
   scanf("%d",&B[i][j]);

   printf("Addition Matrix:\n");
   for(i=0;i<r;i++)
   {
      for(j=0;j<c;j++)
      {
         sum[i][j]=A[i][j]+B[i][j];
         printf("%d ",sum[i][j]);
      }
      printf("\n");
   }

   // 2. Saddle Point
   int min,col,flag=0;

   printf("\nEnter matrix for Saddle Point:\n");
   for(i=0;i<r;i++)
   for(j=0;j<c;j++)
   scanf("%d",&A[i][j]);

   for(i=0;i<r;i++)
   {
      min=A[i][0];
      col=0;

      for(j=1;j<c;j++)
      {
         if(A[i][j]<min)
         {
            min=A[i][j];
            col=j;
         }
      }

      flag=1;
      for(j=0;j<r;j++)
      {
         if(A[j][col]>min)
         flag=0;
      }

      if(flag)
      {
         printf("Saddle Point=%d\n",min);
         break;
      }
   }

   // 3. Inverse of 2x2 Matrix
   float det;

   printf("\nEnter 2x2 Matrix:\n");
   for(i=0;i<2;i++)
   for(j=0;j<2;j++)
   scanf("%d",&A[i][j]);

   det=(A[0][0]*A[1][1])-(A[0][1]*A[1][0]);

   if(det!=0)
   {
      printf("Inverse Matrix:\n");
      printf("%.2f %.2f\n",A[1][1]/det,-A[0][1]/det);
      printf("%.2f %.2f\n",-A[1][0]/det,A[0][0]/det);
   }

   // 4. Magic Square Check
   int n,sum1=0,sum2=0,magic=1,rowsum;

   printf("\nEnter order of square matrix: ");
   scanf("%d",&n);

   printf("Enter Matrix:\n");
   for(i=0;i<n;i++)
   for(j=0;j<n;j++)
   scanf("%d",&A[i][j]);

   for(j=0;j<n;j++)
   sum1+=A[0][j];

   for(i=0;i<n;i++)
   {
      rowsum=0;
      for(j=0;j<n;j++)
      rowsum+=A[i][j];

      if(rowsum!=sum1)
      magic=0;
   }

   for(i=0;i<n;i++)
   sum2+=A[i][i];

   if(magic && sum1==sum2)
      printf("Magic Square");
   else
      printf("Not Magic Square");

   return 0;
}
