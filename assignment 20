#include <stdio.h>

// Without Pointers
void swap1(int a, int b)
{
    int temp;

    temp = a;
    a = b;
    b = temp;

    printf("After swapping without pointers: %d %d\n",a,b);
}

// With Pointers
void swap2(int *a, int *b)
{
    int temp;

    temp = *a;
    *a = *b;
    *b = temp;
}

int main()
{
    int x,y;

    printf("Enter two numbers: ");
    scanf("%d%d",&x,&y);

    swap1(x,y);

    swap2(&x,&y);

    printf("After swapping with pointers: %d %d",x,y);

    return 0;
}
